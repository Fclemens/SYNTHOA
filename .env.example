# Copy to .env and fill in. docker compose reads this automatically.

# ── LLM providers ─────────────────────────────────────────────────────────────
# At least one must be set.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=

# If you run a local OpenAI-compatible server (LM Studio, Ollama, vLLM),
# point this at it. Must be reachable FROM THE BACKEND CONTAINER — on Docker
# Desktop (Win/Mac) that is http://host.docker.internal:1234/v1
LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1

# ── Execution limits ──────────────────────────────────────────────────────────
MAX_CONCURRENT_TASKS=10
TPM_LIMIT=2000000

# ── Ports ─────────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ── Frontend → Backend URL (baked into the client bundle at build time) ──────
# Must be reachable from the user's BROWSER. Default works for local Docker.
# When deploying, set to your public backend URL and run `docker compose build frontend`.
NEXT_PUBLIC_API_URL=http://localhost:8000
