# ── LLM Provider ──────────────────────────────────────────────────────────────
# OpenAI API key (required unless using a local model)
OPENAI_API_KEY=sk-...

# Optional: override base URL for local models (Ollama, vLLM, LM Studio)
# Example for Ollama: http://localhost:11434/v1
# Leave unset to use the official OpenAI API
OPENAI_BASE_URL=

# Default models (can be overridden per-run in the API)
MODEL_PASS1=gpt-4o
MODEL_PASS2=gpt-4o-mini

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite path (relative to backend/ dir, or absolute)
DATABASE_URL=sqlite+aiosqlite:///./genai_simulator.db

# ── Execution ─────────────────────────────────────────────────────────────────
# Max concurrent LLM tasks
MAX_CONCURRENT_TASKS=10
# Tokens per minute budget (set to OpenAI tier limit or local model capacity)
TPM_LIMIT=2000000

# ── Validation ────────────────────────────────────────────────────────────────
# Plausibility threshold — personas below this are flagged
PLAUSIBILITY_THRESHOLD=0.5
# Max context tokens before truncation warning
MAX_CONTEXT_TOKENS=100000
